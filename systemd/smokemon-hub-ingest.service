[Unit]
Description=smokemon hub ingest (central receiver)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=__SMOKEMON_DIR__
EnvironmentFile=-__ENV_FILE__
ExecStart=__PYTHON__ __SMOKEMON_DIR__/hub_ingest.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
